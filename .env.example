# 环境变量模板 - 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ========== 基础配置 ==========
# 平台访问域名（本地部署填 localhost 或 本机 IP）
DOMAIN=localhost

# ========== 数据库配置 ==========
POSTGRES_USER=devops
POSTGRES_PASSWORD=devops123
POSTGRES_DB=devops_star
POSTGRES_PORT=5432

# ========== Redis 配置 ==========
REDIS_PASSWORD=devops123
REDIS_PORT=6379

# ========== 后端 API 配置 ==========
BACKEND_PORT=8080
JWT_SECRET=devops-star-jwt-secret-change-in-production
GIN_MODE=debug

# ========== Gitea 配置 ==========
GITEA_PORT=3000
GITEA_SSH_PORT=2222
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=admin123
GITEA_ADMIN_EMAIL=admin@devops-star.com

# ========== Harbor 配置 ==========
HARBOR_PORT=8081
HARBOR_ADMIN_PASSWORD=Harbor12345
HARBOR_HOST=localhost

# ========== Grafana 配置 ==========
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin123

# ========== 通知配置（选填） ==========
# 企业微信 Webhook
WECOM_WEBHOOK=

# 钉钉 Webhook
DINGTALK_WEBHOOK=

# 飞书 Webhook
FEISHU_WEBHOOK=

# 邮件 SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ========== 国内镜像加速（自动配置，无需修改） ==========
# Docker 镜像加速列表（init.sh 会自动注入）
DOCKER_MIRROR_1=https://docker.1ms.run
DOCKER_MIRROR_2=https://docker.m.daocloud.io
DOCKER_MIRROR_3=https://mirror.ccs.tencentyun.com

# npm 镜像
NPM_MIRROR=https://registry.npmmirror.com

# Maven 镜像
MAVEN_MIRROR=https://maven.aliyun.com/repository/public

# PyPI 镜像
PYPI_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple

# Go Proxy
GOPROXY=https://goproxy.cn,direct

# ========== 端口映射（可根据需要修改） ==========
FRONTEND_PORT=80
BACKEND_API_PORT=8080
GITEA_WEB_PORT=3000
GITEA_SSH_PORT=2222
HARBOR_PORT=8081
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
